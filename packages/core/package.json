{
  "name": "p2p-hiverelay",
  "version": "0.6.2",
  "description": "HiveRelay Core \u2014 minimal always-on P2P availability infrastructure (seeding, circuit relay, proof-of-relay, gateway)",
  "type": "module",
  "main": "core/index.js",
  "exports": {
    ".": {
      "bare": "./pear-entry.js",
      "default": "./core/index.js"
    },
    "./gateway": "./gateway/hyper-gateway.js",
    "./*": "./*"
  },
  "imports": {
    "events": {
      "bare": "bare-events",
      "default": "events"
    },
    "fs/promises": {
      "bare": "bare-fs/promises",
      "default": "fs/promises"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    },
    "http": {
      "bare": "bare-http1",
      "default": "http"
    }
  },
  "pear": {
    "name": "p2p-hiverelay",
    "type": "terminal",
    "bin": "p2p-hiverelay"
  },
  "bin": {
    "p2p-hiverelay": "./cli/index.js",
    "hiverelay": "./cli/index.js"
  },
  "files": [
    "cli/",
    "core/",
    "gateway/",
    "config/",
    "incentive/",
    "transports/",
    "platform/",
    "pear-entry.js",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.7.15",
    "@hyperswarm/dht-relay": "^0.4.3",
    "@inquirer/prompts": "^8.4.1",
    "@noble/hashes": "^2.2.0",
    "@noble/secp256k1": "^3.1.0",
    "b4a": "^1.6.6",
    "bare-events": "^2.2.0",
    "bare-fs": "^2.1.0",
    "bare-http1": "^4.5.6",
    "bare-path": "^2.1.0",
    "compact-encoding": "^2.15.0",
    "corestore": "^6.18.0",
    "distributed-drive": "^0.1.1",
    "graceful-goodbye": "^1.3.0",
    "holesail": "^2.4.1",
    "hypercore": "^10.36.0",
    "hyperdht": "^6.15.0",
    "hyperdrive": "^11.8.0",
    "hyperswarm": "^4.7.0",
    "minimist": "^1.2.8",
    "multicast-dns": "^7.2.5",
    "pino": "^9.0.0",
    "protomux": "^3.6.0",
    "socks": "^2.8.7",
    "sodium-universal": "^4.0.0",
    "ws": "^8.20.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/bigdestiny2/p2p-hiverelay",
    "directory": "packages/core"
  }
}
