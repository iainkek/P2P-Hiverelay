{
  "name": "p2p-hiverelay-client",
  "version": "0.8.8",
  "description": "Unified client SDK for HiveRelay (Core + Services). Talks to either via capability flags advertised by relay nodes.",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": "./index.js",
    "./pairing.js": "./pairing.js"
  },
  "imports": {
    "events": {
      "bare": "bare-events",
      "default": "events"
    },
    "fs/promises": {
      "bare": "bare-fs/promises",
      "default": "fs/promises"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    },
    "crypto": {
      "bare": "bare-crypto",
      "default": "crypto"
    }
  },
  "files": [
    "index.js",
    "pairing.js",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "b4a": "^1.6.6",
    "bare-crypto": "^1.13.6",
    "bare-events": "^2.2.0",
    "bare-fs": "^2.1.0",
    "bare-path": "^2.1.0",
    "corestore": "^6.18.0",
    "hyperdrive": "^11.8.0",
    "hyperswarm": "^4.7.0",
    "p2p-hiverelay": "0.7.2",
    "sodium-universal": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/bigdestiny2/p2p-hiverelay",
    "directory": "packages/client"
  }
}
